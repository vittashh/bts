<Window x:Class="bts.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="БТС - Управление тахографами" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="5" Margin="0,0,0,10" Padding="10">
            <StackPanel>
                <TextBlock Text="ООО БТС - Управление тахографами" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="г. Уфа, ул. Жукова 28 | +7 (963) 236-08-08" FontSize="12" Foreground="#BDC3C7" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Кнопки навигации -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <Button x:Name="btnClients" Content="📋 Клиенты" Width="120" Height="35" Margin="5" Click="BtnClients_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="btnTachographs" Content="📟 Тахографы" Width="120" Height="35" Margin="5" Click="BtnTachographs_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="btnOrders" Content="📦 Заказы" Width="120" Height="35" Margin="5" Click="BtnOrders_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- Панель управления для клиентов -->
        <Border Grid.Row="2" Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnAddClient" Content="➕ Добавить клиента" Width="140" Height="35" 
                        Margin="5" Background="#27AE60" Foreground="White" FontWeight="Bold"
                        Click="BtnAddClient_Click"/>
                <Button x:Name="btnEditClient" Content="✏ Редактировать" Width="140" Height="35" 
                        Margin="5" Background="#F39C12" Foreground="White" FontWeight="Bold"
                        Click="BtnEditClient_Click" IsEnabled="False"/>
                <Button x:Name="btnDeleteClient" Content="🗑 Удалить" Width="120" Height="35" 
                        Margin="5" Background="#E74C3C" Foreground="White" FontWeight="Bold"
                        Click="BtnDeleteClient_Click" IsEnabled="False"/>
                <Button x:Name="btnRefresh" Content="🔄 Обновить" Width="120" Height="35" 
                        Margin="5" Background="#3498DB" Foreground="White" FontWeight="Bold"
                        Click="BtnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- DataGrid для отображения данных -->
        <DataGrid x:Name="dgData" Grid.Row="3" AutoGenerateColumns="True" 
                  SelectionMode="Single" IsReadOnly="True" 
                  AlternatingRowBackground="#F5F5F5" FontSize="13"
                  SelectionChanged="DgData_SelectionChanged"/>
    </Grid>
</Window>