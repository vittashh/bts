<Window x:Class="bts.ClientEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование клиента" Height="500" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Информация о клиенте" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20" 
                   HorizontalAlignment="Center" Foreground="#2C3E50"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" 
                   VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <TextBox x:Name="tbLastName" Grid.Row="1" Grid.Column="1" 
                 Margin="5" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя:" 
                   VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <TextBox x:Name="tbFirstName" Grid.Row="2" Grid.Column="1" 
                 Margin="5" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Компания:" 
                   VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <TextBox x:Name="tbCompany" Grid.Row="3" Grid.Column="1" 
                 Margin="5" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Телефон:*" 
                   VerticalAlignment="Center" Margin="5" FontSize="14" Foreground="Red"/>
        <TextBox x:Name="tbPhone" Grid.Row="4" Grid.Column="1" 
                 Margin="5" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Email:" 
                   VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <TextBox x:Name="tbEmail" Grid.Row="5" Grid.Column="1" 
                 Margin="5" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Город:" 
                   VerticalAlignment="Center" Margin="5" FontSize="14"/>
        <ComboBox x:Name="cbCity" Grid.Row="6" Grid.Column="1" 
                  Margin="5" Height="35" FontSize="14" IsEditable="True">
            <ComboBoxItem Content="Уфа"/>
            <ComboBoxItem Content="Стерлитамак"/>
            <ComboBoxItem Content="Салават"/>
            <ComboBoxItem Content="Нефтекамск"/>
            <ComboBoxItem Content="Октябрьский"/>
            <ComboBoxItem Content="Туймазы"/>
            <ComboBoxItem Content="Белорецк"/>
            <ComboBoxItem Content="Ишимбай"/>
        </ComboBox>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button x:Name="btnSave" Content="💾 Сохранить" Width="120" Height="40" 
                    Margin="10" Background="#27AE60" Foreground="White" 
                    FontSize="14" FontWeight="Bold" Click="BtnSave_Click"/>
            <Button x:Name="btnCancel" Content="❌ Отмена" Width="120" Height="40" 
                    Margin="10" Background="#E74C3C" Foreground="White" 
                    FontSize="14" FontWeight="Bold" Click="BtnCancel_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Text="* - поле обязательно для заполнения" 
                   FontSize="11" Foreground="Gray" Margin="5,10,0,0"/>
    </Grid>
</Window>